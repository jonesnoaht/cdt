{
  "name": "@cdt/credentials",
  "version": "0.1.0",
  "private": true,
  "description": "Mock W3C Verifiable Credentials 1.1 implementation for the Certificate of Deposit Token (CDT) trust chain: NCUA -> credit union -> member. Self-contained stand-in for Hyperledger Identus.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "npm run typecheck && vitest run",
    "example": "tsc -p tsconfig.json && node dist/example.js"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
