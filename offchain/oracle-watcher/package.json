{
  "name": "@cdt/oracle-watcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CDT oracle watcher: polls the bank Postgres for unattested CD deposits, verifies member verifiable-credential presentations, and emits signed attestations that authorize CDT minting.",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "start": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
